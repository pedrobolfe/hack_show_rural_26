        {
          "name": "Consultar CAR",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/car/:carNumber",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "car", ":carNumber"],
              "variable": [
                {
                  "key": "carNumber",
                  "value": "BR-PR-4104808-ABC123",
                  "description": "Número do CAR no formato BR-UF-MUNICIPIO-NUMERO"
                }
              ]
            },
            "description": "Consulta dados do CAR sem criar propriedade. Retorna informações como área total, reserva legal, APP, localização, etc."
          },
          "response": []
