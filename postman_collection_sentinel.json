{
  "info": {
    "name": "Hack Show Rural - Sentinel Hub API",
    "description": "Rotas para obter token OAuth2 e URLs de imagens Sentinel-2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Obter Token OAuth2",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "http://localhost:3000/api/properties/satellite/token",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "properties", "satellite", "token"]
        }
      }
    },
    {
      "name": "Obter URL da Imagem com Coordenadas",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"coordinates\": [\n    {\"lat\": -24.74626, \"lon\": -53.56975},\n    {\"lat\": -24.74626, \"lon\": -53.56975},\n    {\"lat\": -24.74626, \"lon\": -53.56975}\n  ],\n  \"date\": \"2024-12-01\",\n  \"spanMeters\": 1200\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/properties/satellite/image-url",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "properties", "satellite", "image-url"]
        }
      }
    },
    {
      "name": "Fazer Download da Imagem (usar dados da rota anterior)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "image/png"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{request_body}}"
        },
        "url": {
          "raw": "https://sh.dataspace.copernicus.eu/api/v1/process",
          "protocol": "https",
          "host": ["sh", "dataspace", "copernicus", "eu"],
          "path": ["api", "v1", "process"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "request_body",
      "value": "",
      "type": "string"
    }
  ]
}