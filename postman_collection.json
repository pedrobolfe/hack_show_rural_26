              "raw": "{{baseUrl}}/api/properties/satellite/bbox?bbox=-53.5716,-24.7485,-53.5670,-24.7450&dateFrom=2024-01-01T00:00:00Z&dateTo=2024-12-31T23:59:59Z&label=Área Teste&width=1024&height=1024&returnPath=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "satellite", "bbox"],
              "query": [
                {
                  "key": "bbox",
                  "value": "-53.5716,-24.7485,-53.5670,-24.7450",
                  "description": "Bounding box: [oeste,sul,leste,norte]"
                },
                {
                  "key": "dateFrom",
                  "value": "2024-01-01T00:00:00Z",
                  "description": "Data inicial (opcional)"
                },
                {
                  "key": "dateTo",
                  "value": "2024-12-31T23:59:59Z",
                  "description": "Data final (opcional)"
                },
                {
                  "key": "label",
                  "value": "Área Teste",
                  "description": "Label na imagem (opcional)"
                },
                {
                  "key": "width",
                  "value": "1024",
                  "description": "Largura em pixels (opcional)"
                },
                {
                  "key": "height",
                  "value": "1024",
                  "description": "Altura em pixels (opcional)"
                },
                {
                  "key": "returnPath",
                  "value": "true",
                  "description": "Retornar caminho JSON ou imagem direta"
                }
              ]
            },
            "description": "Obtém imagem de satélite destacada apenas com o bounding box. Mais simples que o polígono."
          },
          "response": []
        }
