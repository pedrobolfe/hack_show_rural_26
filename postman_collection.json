{
  "info": {
    "name": "Sistema de Inventário de Propriedades Rurais API",
    "description": "Coleção completa de endpoints da API - Cadastro → Questionário → Satélite → Relatório",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Verifica se a API está funcionando e retorna informações sobre os endpoints disponíveis"
      },
      "response": []
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Criar Usuário (Produtor)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao.silva@example.com\",\n  \"phone\": \"(11) 98765-4321\",\n  \"role\": \"produtor\",\n  \"userType\": \"produtor\",\n  \"numCRA\": \"MS-5401405-ABCD1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            },
            "description": "Cria um novo usuário produtor rural"
          },
          "response": []
        },
        {
          "name": "Listar Todos os Usuários",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Número máximo de resultados"
                }
              ]
            },
            "description": "Retorna lista de todos os usuários com limite opcional"
          },
          "response": []
        },
        {
          "name": "Buscar Usuário por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "USER_ID_AQUI"
                }
              ]
            },
            "description": "Busca usuário específico por ID"
          },
          "response": []
        },
        {
          "name": "Buscar Usuário por Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/email/:email",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "email", ":email"],
              "variable": [
                {
                  "key": "email",
                  "value": "joao.silva@example.com"
                }
              ]
            },
            "description": "Busca usuário por endereço de email"
          },
          "response": []
        },
        {
          "name": "Buscar Usuário por Número CAR",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/car/:numCRA",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "car", ":numCRA"],
              "variable": [
                {
                  "key": "numCRA",
                  "value": "MS-5401405-ABCD1234567890"
                }
              ]
            },
            "description": "Busca usuário pelo número do CAR"
          },
          "response": []
        },
        {
          "name": "Atualizar Usuário",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva Atualizado\",\n  \"phone\": \"(11) 91234-5678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "USER_ID_AQUI"
                }
              ]
            },
            "description": "Atualiza dados de um usuário existente"
          },
          "response": []
        },
        {
          "name": "Deletar Usuário",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "USER_ID_AQUI"
                }
              ]
            },
            "description": "Remove um usuário do sistema"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Consultar Dados do CAR (Sem Criar Propriedade)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/car/:carNumber",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "car", ":carNumber"],
              "variable": [
                {
                  "key": "carNumber",
                  "value": "MS-5401405-ABCD1234567890"
                }
              ]
            },
            "description": "Consulta dados do CAR sem criar uma propriedade"
          },
          "response": []
        },
        {
          "name": "Criar Propriedade",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerId\": \"USER_ID_AQUI\",\n  \"carData\": {\n    \"number\": \"MS-5401405-ABCD1234567890\",\n    \"legalReserve\": 20,\n    \"app\": 10,\n    \"validated\": false\n  },\n  \"location\": {\n    \"city\": \"Campo Grande\",\n    \"state\": \"MS\",\n    \"center\": {\n      \"lat\": -20.4697,\n      \"lng\": -54.6201\n    }\n  },\n  \"status\": \"Pending\",\n  \"areaDetails\": {\n    \"total\": 100,\n    \"forest\": 30,\n    \"app\": 10,\n    \"productive\": 60,\n    \"legalReserve\": 20\n  },\n  \"pooling\": {\n    \"isInCluster\": false\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties"]
            },
            "description": "Cria uma nova propriedade rural"
          },
          "response": []
        },
        {
          "name": "Sincronizar Dados do CAR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carNumber\": \"MS-5401405-ABCD1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties/:propertyId/sync-car",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", ":propertyId", "sync-car"],
              "variable": [
                {
                  "key": "propertyId",
                  "value": "PROPERTY_ID_AQUI"
                }
              ]
            },
            "description": "Sincroniza dados do CAR para uma propriedade existente"
          },
          "response": []
        },
        {
          "name": "Listar Todas as Propriedades",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties"],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Número máximo de resultados"
                }
              ]
            },
            "description": "Retorna lista de todas as propriedades"
          },
          "response": []
        },
        {
          "name": "Buscar Propriedade por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PROPERTY_ID_AQUI"
                }
              ]
            },
            "description": "Busca propriedade específica por ID"
          },
          "response": []
        },
        {
          "name": "Buscar Propriedades por Proprietário",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/owner/:ownerId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "owner", ":ownerId"],
              "variable": [
                {
                  "key": "ownerId",
                  "value": "USER_ID_AQUI"
                }
              ]
            },
            "description": "Retorna todas as propriedades de um proprietário específico"
          },
          "response": []
        },
        {
          "name": "Buscar Propriedades Sem Cluster",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/without-cluster",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "without-cluster"]
            },
            "description": "Retorna propriedades que não estão em nenhum cluster"
          },
          "response": []
        },
        {
          "name": "Atualizar Status da Propriedade",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", ":id", "status"],
              "variable": [
                {
                  "key": "id",
                  "value": "PROPERTY_ID_AQUI"
                }
              ]
            },
            "description": "Atualiza o status de uma propriedade (Active, Pending, Alert)"
          },
          "response": []
        },
        {
          "name": "Deletar Propriedade",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PROPERTY_ID_AQUI"
                }
              ]
            },
            "description": "Remove uma propriedade do sistema"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Satellite",
      "item": [
        {
          "name": "Obter Token Sentinel Hub",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/satellite/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "satellite", "token"]
            },
            "description": "Obtém token OAuth2 do Sentinel Hub"
          },
          "response": []
        },
        {
          "name": "Obter URL da Imagem com Coordenadas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coordinates\": [\n    [-53.6, -24.78],\n    [-53.55, -24.78],\n    [-53.55, -24.73],\n    [-53.6, -24.73],\n    [-53.6, -24.78]\n  ],\n  \"date\": \"2024-06-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties/satellite/image-url",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "satellite", "image-url"]
            },
            "description": "Retorna URL da imagem de satélite sem fazer download"
          },
          "response": []
        },
        {
          "name": "Obter Imagem com Polígono (Coordenadas)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coordinates\": [\n    [-53.6, -24.78],\n    [-53.55, -24.78],\n    [-53.55, -24.73],\n    [-53.6, -24.73],\n    [-53.6, -24.78]\n  ],\n  \"date\": \"2024-06-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/properties/satellite/polygon",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "satellite", "polygon"]
            },
            "description": "Gera imagem de satélite com polígono desenhado a partir de coordenadas"
          },
          "response": []
        },
        {
          "name": "Obter Imagem com Polígono (JSON)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/satellite/polygon-json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "satellite", "polygon-json"]
            },
            "description": "Gera imagem de satélite a partir do arquivo coordenadas.json"
          },
          "response": []
        },
        {
          "name": "Obter Imagem por BBOX",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/properties/satellite/bbox?bbox=-53.60,-24.78,-53.55,-24.73&date=2024-06-15&width=1024&height=1024",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties", "satellite", "bbox"],
              "query": [
                {
                  "key": "bbox",
                  "value": "-53.60,-24.78,-53.55,-24.73",
                  "description": "Bounding box: minLon,minLat,maxLon,maxLat"
                },
                {
                  "key": "date",
                  "value": "2024-06-15",
                  "description": "Data da imagem (formato: YYYY-MM-DD)"
                },
                {
                  "key": "width",
                  "value": "1024",
                  "description": "Largura da imagem em pixels"
                },
                {
                  "key": "height",
                  "value": "1024",
                  "description": "Altura da imagem em pixels"
                }
              ]
            },
            "description": "Obtém imagem de satélite por bounding box"
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI Analysis",
      "item": [
        {
          "name": "Analisar Imagem com IA",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Analise esta imagem de satélite e identifique áreas de vegetação, desmatamento e corpos d'água.\",\n  \"inputs\": {\n    \"areaTotal\": 100,\n    \"coordenadas\": [\n      [-53.6, -24.78],\n      [-53.55, -24.78],\n      [-53.55, -24.73],\n      [-53.6, -24.73],\n      [-53.6, -24.78]\n    ],\n    \"usoSoloAtual\": \"pastagem\",\n    \"historicoUso\": \"Área anteriormente utilizada para agricultura extensiva\",\n    \"dadosAdicionais\": \"Solo argiloso, clima subtropical, precipitação média de 1500mm/ano\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "analyze"]
            },
            "description": "Analisa a imagem src/assets/image.png com prompt personalizado e dados da propriedade"
          },
          "response": []
        },
        {
          "name": "Gerar Relatório em Markdown",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Gere um relatório detalhado sobre o uso do solo, incluindo métricas de vegetação e áreas produtivas.\",\n  \"inputs\": {\n    \"areaTotal\": 100,\n    \"coordenadas\": [\n      [-53.6, -24.78],\n      [-53.55, -24.78],\n      [-53.55, -24.73],\n      [-53.6, -24.73],\n      [-53.6, -24.78]\n    ],\n    \"usoSoloAtual\": \"pastagem\",\n    \"historicoUso\": \"Conversão de floresta para pastagem em 2010\",\n    \"dadosAdicionais\": \"Capacidade de suporte: 1 UA/ha, sistema de rotação de pastagens implementado\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "report"]
            },
            "description": "Gera relatório em formato Markdown da análise com dados da propriedade"
          },
          "response": []
        },
        {
          "name": "Salvar Relatório em Arquivo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Crie um relatório completo de análise ambiental da propriedade rural para inventário de GEE.\",\n  \"inputs\": {\n    \"areaTotal\": 150,\n    \"coordenadas\": [\n      [-53.6, -24.78],\n      [-53.55, -24.78],\n      [-53.55, -24.73],\n      [-53.6, -24.73],\n      [-53.6, -24.78]\n    ],\n    \"usoSoloAtual\": \"agricultura - soja\",\n    \"historicoUso\": \"Área de floresta nativa até 2005, convertida para agricultura de grãos\",\n    \"dadosAdicionais\": \"Sistema de plantio direto desde 2015, rotação soja-milho, uso de fertilizantes nitrogenados 150kg N/ha/ano\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/save-report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "save-report"]
            },
            "description": "Salva o relatório gerado em arquivo .md na pasta reports/ com dados completos da propriedade"
          },
          "response": []
        }
      ]
    }
  ]
}
